{
  "title": "Community Topics Bento",
  "description": "A modern bento-grid layout showcasing community topics with hover interactions, metadata stats, and content-type badges.",
  "category": "Community",
  "source": {
    "path": "dist",
    "entry": "content.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "title",
        "type": "text",
        "label": "Section Title",
        "defaultValue": "Community Topics",
        "rules": {
          "required": true
        }
      },
      {
        "name": "viewAllUrl",
        "type": "text",
        "label": "View All URL",
        "defaultValue": "#"
      }
    ]
  },
  "defaultConfig": {
    "title": "Community Topics",
    "viewAllUrl": "#"
  }
}
